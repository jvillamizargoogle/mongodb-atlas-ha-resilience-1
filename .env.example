PORT=3001
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=atlas_ha_demo
MONGODB_COLLECTION_NAME=resilience_events
APP_REGION=us-east-1
APP_CLOUD_PROVIDER=aws

# Atlas Admin API — keep these server-side only
ATLAS_PUBLIC_KEY=your-atlas-public-key
ATLAS_PRIVATE_KEY=your-atlas-private-key
ATLAS_PROJECT_ID=your-project-id
ATLAS_CLUSTER_NAME=your-cluster-name
ATLAS_API_BASE_URL=https://cloud.mongodb.com/api/atlas/v2

# Feature flags
ENABLE_ATLAS_CONTROL_PLANE=false
ENABLE_DESTRUCTIVE_ACTIONS=false

# Workload defaults
DEFAULT_READ_PREFERENCE=primary
DEFAULT_WRITE_CONCERN=majority
DEFAULT_WORKLOAD_CONCURRENCY=5
DEFAULT_WORKLOAD_INTERVAL_MS=200
